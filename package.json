{
  "name": "nexus-bot",
  "version": "1.0.0",
  "description": "All-in-one Discord server management bot",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:hosted": "node scripts/start-hosted.js",
    "dev": "node --watch index.js",
    "host": "node host/server.js",
    "host:quiet": "node host/server.js",
    "site": "node website/server.js",
    "site:open": "node website/server.js",
    "test:security": "node --test website/security.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "discord.js": "^14.16.3",
    "stripe": "^17.7.0"
  }
}
