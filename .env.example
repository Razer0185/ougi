# Copy to .env in the project root (never commit real keys)
# Get keys: https://dashboard.stripe.com/apikeys

STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_KEY

# PayPal Transaction Search (optional — verifies buyer Transaction IDs)
# https://developer.paypal.com/dashboard/applications
# Enable "Transaction Search" on the Live app. Business account recommended.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live

# Google sign-in — https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (type: Web application)
# Authorized JavaScript origins:
#   http://127.0.0.1:5050
#   https://ougi-production.up.railway.app
# Authorized redirect URIs:
#   http://127.0.0.1:5050/api/account/google/callback
#   https://ougi-production.up.railway.app/api/account/google/callback
# Client ID alone is enough for Continue with Google (popup).
# Client Secret enables full-page redirect fallback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional site settings
OUGI_SITE_PORT=5050
OUGI_SITE_HOST=127.0.0.1
OUGI_SITE_ORIGIN=http://127.0.0.1:5050

# AI (ask / askbuild) — put keys in files OR here (never commit real keys)
# you-api-key.txt  OR:
YDC_API_KEY=
# Optional Gemini (better JSON layouts) — https://aistudio.google.com/apikey
# gemini-api-key.txt  OR:
GEMINI_API_KEY=
